{
  "name": "aios-law",
  "version": "1.0.0",
  "description": "AI-Orchestrated System for Legal Practice — Framework de orquestração multi-agente para advocacia",
  "main": ".aios-law/index.js",
  "scripts": {
    "sync:ide": "node .aios-law/scripts/sync-ide.js",
    "sync:ide:claude": "node .aios-law/scripts/sync-ide.js --target claude-code",
    "sync:ide:cursor": "node .aios-law/scripts/sync-ide.js --target cursor",
    "sync:ide:codex": "node .aios-law/scripts/sync-ide.js --target codex",
    "validate:parity": "node .aios-law/scripts/validate-parity.js",
    "validate:agents": "node .aios-law/scripts/validate-agents.js",
    "doctor": "node bin/aios-law.js doctor",
    "info": "node bin/aios-law.js info"
  },
  "keywords": [
    "ai",
    "legal",
    "law",
    "advocacy",
    "multi-agent",
    "orchestration",
    "framework",
    "brazilian-law"
